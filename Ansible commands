# To clean-up the trash and trash-amnesia from maqui
source /etc/logtrust/systemd/metamalote/common.conf.sh;

/usr/local/bin/maqui -m localhost:10100 \
-Llinq -u "${KSIGNER_USER}" \
"$(/usr/local/bin/signer -u "${KSIGNER_USER}" \
    -k /etc/logtrust/malote/.ks/metamalote.jks \
    --priv-key-pwd "${KSIGNER_PASS}" \
    --key-store-pwd "${KS_PASS}" \
   -q 'from system.delegated.internal.trash  where strategy="trash-amnesia" and deletionTime <= now()-1d select  (instance(databaseinfo()) + ":" + deletionId + "," + originalPath) as trashfile, delete(trashedFile, $AUTHENTICATE$ as sign) as deleted pragma table.si.trash.filter.id.required: "none"')"

