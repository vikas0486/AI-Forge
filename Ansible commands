  $1 ~ /[0-9]+[MG]/ {
    num = substr($1, 1, length($1)-1)
    unit = substr($1, length($1), 1)
    size_mb = (unit=="G" ? num * 1024 : num)
    n = split($2, a, "/"); domain = a[n]
    arr[domain] += size_mb; mon[domain]=month
  }
  END {
    for (d in arr) {
      if (d=="total") continue
      gb = arr[d]/1024
      printf "%.3f\t%s\t%s\n", gb, d, mon[d]
    }
  }' | sort -k1 -nr; done; done | column -t > old-2024.txt


