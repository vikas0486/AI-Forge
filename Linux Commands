{ ( NUM_DISKS=8; \
NUM_TRUNKS=2; \
START_DISK=0; \
START_TRUNK=0; \
MAX_PARALLEL=16; \
START_DAY=20; \
END_DAY=21; \
YEAR='2024'; \
MONTH='01'; \
for day in $(seq -w ${START_DAY} ${END_DAY}); do \
    ebs_num=${START_DISK}; \
    while true; do \
        declare pid_list=(); \
        for ebs in $(seq "${ebs_num}" "$(( START_DISK + NUM_DISKS - 1))" ); do \
            for trunk_num in $(seq ${START_TRUNK} "$(( START_TRUNK + NUM_TRUNKS -1 ))"); do \
                mkdir -p -v /var/logt/backup/logs/rsync/; \
                chown logtrust:logtrust /var/logt/backup/logs/rsync/; \
                mkdir -p -v "/var/logt/backup/tr${ebs}/b0${trunk_num}/t00/${YEAR}/${MONTH}/${day}"; \
                chown -R -v logtrust:logtrust /var/logt/backup/tr${ebs}; \
                /bin/bash -c "/usr/bin/nocache /usr/bin/rsync -av --delete --owner --group --perms --times \"/var/logt/tr${ebs}/b0${trunk_num}/t00/${YEAR}/${MONTH}/${day}/\" \"/var/logt/backup/tr${ebs}/b0${trunk_num}/t00/${YEAR}/${MONTH}/${day}\"  2>&1 | tee -a \"/var/logt/backup/logs/rsync/rsync_yng_2_backup-yng_${YEAR}-${MONTH}-${day}_ssd${ebs}-b0${trunk_num}.log\" | cat" & \
                pid="$!"; \
                pid_list[${#pid_list[@]}]="$pid"; \
        done; \
            if [[ "${#pid_list[@]}" -eq "${MAX_PARALLEL}" ]]; then \
                break ; \
            fi; \
        done; \
        ebs_num=$(( ebs + 1 )); \
        for process in "${pid_list[@]}"; do \
            wait "${process}"; \
        done; \
        if [[ "${ebs_num}" -eq "$(( START_DISK + NUM_DISKS ))" ]]; then \
            if [[ ${trunk_num} -eq "$(( START_TRUNK + NUM_TRUNKS - 1 ))" ]]; then \
                break ; \
            fi; \
        fi; \
    done; \
done; ) }

