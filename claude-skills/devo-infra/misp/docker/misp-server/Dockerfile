FROM debian:stable
MAINTAINER Sebastien Tricaud <sebastien.tricaud@devo.com>

#
# Settings (inspired from https://misp.github.io/MISP/INSTALL.debian9/)
# 
ARG MISP_USER="misp"
ARG MISP_PASSWORD="Password1234"
ARG WWW_USER="www-data"
ARG PATH_TO_MISP="/var/www/MISP"
ARG MISP_BASEURL="https://misp.devo.com"

# Database configuration
ARG DBHOST="localhost"
ARG DBNAME="misp"
ARG DBUSER_ADMIN="root"
ARG DBPASSWORD_ADMIN="Password1234"
ARG DBUSER_MISP="misp"
ARG DBPASSWORD_MISP="Password1234"

# OpenSSL configuration
ARG OPENSSL_CN=$FQDN
ARG OPENSSL_C="LU"
ARG OPENSSL_ST="State"
ARG OPENSSL_L="Location"
ARG OPENSSL_O="Organization"
ARG OPENSSL_OU="Organizational Unit"
ARG OPENSSL_EMAILADDRESS="info@$FQDN"

# GPG configuration
ARG GPG_REAL_NAME="Autogenerated Key"
ARG GPG_COMMENT="WARNING: MISP AutoGenerated Key consider this Key VOID!"
ARG GPG_EMAIL_ADDRESS="admin@admin.test"
ARG GPG_KEY_LENGTH="2048"
ARG GPG_PASSPHRASE="Password1234"

ARG POSTFIX_RELAYHOST="devo.com"

ARG FLAVOUR="Devo MISP"
#
# End of settings
#


# For Python3, we must have > Python 3.6 for bgp ranking MISP module (see https://github.com/MISP/misp-modules/issues/270)
#
RUN echo "deb http://deb.debian.org/debian testing main" >> /etc/apt/sources.list
RUN echo 'APT::Default-Release "stable";' | tee -a /etc/apt/apt.conf.d/00local


#
# Start installing packages
#
RUN apt update
RUN apt install -y etckeeper
##RUN apt install -y postfix
RUN apt install -y curl gcc git gnupg-agent make openssl redis-server vim zip libyara-dev virtualenv mariadb-client mariadb-server apache2 apache2-doc apache2-utils libapache2-mod-php7.0 php7.0 php7.0-cli php7.0-mbstring php7.0-dev php7.0-json php7.0-xml php7.0-mysql php7.0-opcache php7.0-readline php-redis php-gnupg libpq5 libjpeg-dev libfuzzy-dev ruby asciidoctor jq ntp ntpdate jupyter-notebook imagemagick tesseract-ocr libxml2-dev libxslt1-dev zlib1g-dev systemd net-tools

# Run Python install from testing to get Python 3.6
RUN apt install -t testing python3.7 python3-setuptools python3-dev python3-pip python3-redis python3-zmq -y

RUN mysqld_safe & 

# Start haveged to get more entropy (optional)
##RUN apt install haveged -y
##RUN service havegd start

RUN apt install expect -y

# A machine without emacs is not a machine
RUN apt install emacs-nox -y

#
# End Packages installation
#

RUN groupadd $MISP_USER
RUN useradd -m -s /bin/bash $MISP_USER -g $WWW_USER

##RUN postconf -e "relayhost = $POSTFIX_RELAYHOST"
##RUN postfix reload

#
# Apache configuration
#
# Enable modules, settings, and default of SSL in Apache
RUN a2dismod status
RUN a2enmod ssl rewrite
RUN a2dissite 000-default
RUN a2ensite default-ssl
RUN a2enmod headers
##RUN systemctl restart apache2


#
# MISP 
#
RUN mkdir -p $PATH_TO_MISP
RUN chown $WWW_USER:$WWW_USER $PATH_TO_MISP
WORKDIR $PATH_TO_MISP
##USER $MISP_USER
RUN git clone http://github.com/MISP/MISP.git $PATH_TO_MISP
#
# MISP Modules
#
RUN mkdir $PATH_TO_MISP/misp-modules
WORKDIR $PATH_TO_MISP/misp-modules
RUN git clone https://github.com/MISP/misp-modules.git $PATH_TO_MISP/misp-modules
# This is the error we have when running pip3 install -I -r REQUIREMENTS:
# Collecting url-normalize==1.4.1 (from -r REQUIREMENTS (line 60))
#   Could not find a version that satisfies the requirement url-normalize==1.4.1 (from -r REQUIREMENTS (line 60)) (from versions: 1.2.1, 1.3.1, 1.3.3)
# No matching distribution found for url-normalize==1.4.1 (from -r REQUIREMENTS (line 60))
# ---> So we have this workaround, as I don't this where this *exact* version is required
RUN sed -i "s/url-normalize==1.4.1/url-normalize/" $PATH_TO_MISP/misp-modules/REQUIREMENTS
RUN pip3 install -I -r REQUIREMENTS
RUN pip3 install -I .
RUN echo "sudo -u www-data misp-modules -s -l 127.0.0.1 &" >>/etc/rc.local

# Make git ignore filesystem permission differences
RUN git config core.filemode false
# Create a python3 virtualenv
RUN virtualenv -p python3 $PATH_TO_MISP/venv

# make pip happy
RUN mkdir /var/www/.cache/
RUN chown $WWW_USER:$WWW_USER /var/www/.cache

WORKDIR $PATH_TO_MISP/app/files/scripts
RUN git clone https://github.com/CybOXProject/python-cybox.git
RUN git clone https://github.com/STIXProject/python-stix.git
RUN git clone https://github.com/MAECProject/python-maec.git
# install mixbox to accommodate the new STIX dependencies:
RUN git clone https://github.com/CybOXProject/mixbox.git
WORKDIR $PATH_TO_MISP/app/files/scripts/python-cybox
RUN $PATH_TO_MISP/venv/bin/pip install .
WORKDIR $PATH_TO_MISP/app/files/scripts/python-stix
RUN $PATH_TO_MISP/venv/bin/pip install .
WORKDIR $PATH_TO_MISP/app/files/scripts/python-maec
RUN $PATH_TO_MISP/venv/bin/pip install .
WORKDIR $PATH_TO_MISP/app/files/scripts/mixbox
RUN $PATH_TO_MISP/venv/bin/pip install .
# install STIX 2.0 library to support STIX 2.0 export:
##WORKDIR $PATH_TO_MISP/cti-python-stix2
##RUN $PATH_TO_MISP/venv/bin/pip install .

WORKDIR $PATH_TO_MISP
RUN git submodule update --init --recursive
# Make git ignore filesystem permission differences for submodules
RUN git submodule foreach --recursive git config core.filemode false

# install PyMISP
WORKDIR $PATH_TO_MISP/PyMISP
RUN $PATH_TO_MISP/venv/bin/pip install .

# Install Crypt_GPG and Console_CommandLine
RUN pear install $PATH_TO_MISP/INSTALL/dependencies/Console_CommandLine/package.xml
RUN pear install $PATH_TO_MISP/INSTALL/dependencies/Crypt_GPG/package.xml

#
# CakePHP
#
# Install CakeResque along with its dependencies if you intend to use the built in background jobs:
WORKDIR $PATH_TO_MISP/app
RUN mkdir -p /var/www/MISP/app/vendor
# Make composer cache happy
RUN mkdir /var/www/.composer
RUN chown -R $WWW_USER:$WWW_USER /var/www/
RUN touch $PATH_TO_MISP/app/composer.json
RUN chown $WWW_USER:$WWW_USER $PATH_TO_MISP/app/composer.json
USER $WWW_USER
RUN php composer.phar require kamisama/cake-resque:4.1.2
RUN php composer.phar config vendor-dir Vendor
RUN php composer.phar install

# Enable CakeResque with php-redis
USER root
RUN phpenmod redis
RUN phpenmod gnupg

# To use the scheduler worker for scheduled tasks, do the following:
RUN cp -fa $PATH_TO_MISP/INSTALL/setup/config.php $PATH_TO_MISP/app/Plugin/CakeResque/Config/config.php

#
# Set permissions
#
# Check if the permissions are set correctly using the following commands:
RUN chown -R $WWW_USER:$WWW_USER $PATH_TO_MISP
RUN chmod -R 750 $PATH_TO_MISP
RUN chmod -R g+ws $PATH_TO_MISP/app/tmp
RUN chmod -R g+ws $PATH_TO_MISP/app/files
RUN chmod -R g+ws $PATH_TO_MISP/app/files/scripts/tmp

#
# Database
#
COPY scripts/1_prepareDB.sh /tmp/
RUN /tmp/1_prepareDB.sh "$MISP_PASSWORD" "$DBUSER_ADMIN" "$DBPASSWORD_ADMIN" "$DBNAME" "$PATH_TO_MISP" "$DBUSER_MISP" "$DBPASSWORD_MISP"


#
# 7) Apache Configuration
#

RUN cp $PATH_TO_MISP/INSTALL/apache.24.misp.ssl /etc/apache2/sites-available/misp-ssl.conf

## We create our self-sign certificate 
RUN openssl req -newkey rsa:4096 -days 365 -nodes -x509 \
	-subj "/C=$OPENSSL_C/ST=$OPENSSL_ST/L=$OPENSSL_L/O=$OPENSSL_O/OU=$OPENSSL_OU/CN=$OPENSSL_CN/emailAddress=$OPENSSL_EMAILADDRESS" \
	-keyout /etc/ssl/private/misp.local.key -out /etc/ssl/private/misp.local.crt

## Enable modules, settings, and default of SSL in Apache
RUN a2dismod status
RUN a2enmod ssl
RUN a2enmod rewrite
RUN a2enmod headers
RUN a2dissite 000-default
RUN a2ensite default-ssl

## Apply all changes
#RUN apt install systemd -y
#RUN systemctl restart apache2
## activate new vhost
RUN a2dissite default-ssl
RUN a2ensite misp-ssl

## Restart apache
#RUN systemctl restart apache2

#
# 8) Log rotation
#
RUN cp $PATH_TO_MISP/INSTALL/misp.logrotate /etc/logrotate.d/misp
RUN chmod 0640 /etc/logrotate.d/misp


#
# 9) MISP Configuration
#
USER $WWW_USER
## There are 4 sample configuration files in ${PATH_TO_MISP}/app/Config that need to be copied
RUN cp -a $PATH_TO_MISP/app/Config/bootstrap.default.php $PATH_TO_MISP/app/Config/bootstrap.php
RUN cp -a $PATH_TO_MISP/app/Config/database.default.php $PATH_TO_MISP/app/Config/database.php
RUN cp -a $PATH_TO_MISP/app/Config/core.default.php $PATH_TO_MISP/app/Config/core.php
RUN cp -a $PATH_TO_MISP/app/Config/config.default.php $PATH_TO_MISP/app/Config/config.php

RUN echo "<?php\n \
  class DATABASE_CONFIG {\n \
          public \$default = array(\n \
                  'datasource' => 'Database/Mysql',\n \
                  //'datasource' => 'Database/Postgres',\n \
                  'persistent' => false,\n \
                  'host' => '$DBHOST',\n \
                  'login' => '$DBUSER_MISP',\n \
                  'port' => 3306, // MySQL & MariaDB\n \
                  //'port' => 5432, // PostgreSQL\n \
                  'password' => '$DBPASSWORD_MISP',\n \
                  'database' => '$DBNAME',\n \
                  'prefix' => '',\n \
                  'encoding' => 'utf8',\n \
          );\n \
  }" | tee $PATH_TO_MISP/app/Config/database.php

## Important! Change the salt key in $PATH_TO_MISP/app/Config/config.php
## The salt key must be a string at least 32 bytes long.
## The admin user account will be generated on the first login, make sure that the salt is changed before you create that user
## If you forget to do this step, and you are still dealing with a fresh installation, just alter the salt,
## delete the user from mysql and log in again using the default admin credentials (admin@admin.test / admin)
RUN sed -i "s/'salt'       => '',/'salt'       => 'Th1sIS0urS4ltATdevo',/" $PATH_TO_MISP/app/Config/config.php

## and make sure the file permissions are still OK
USER root
RUN chown -R www-data:www-data $PATH_TO_MISP/app/Config
RUN chmod -R 750 $PATH_TO_MISP/app/Config

# GnuPG
RUN echo "%echo Generating a default key\n \
      Key-Type: default\n \
      Key-Length: $GPG_KEY_LENGTH\n \
      Subkey-Type: default\n \
      Name-Real: $GPG_REAL_NAME\n \
      Name-Comment: $GPG_COMMENT\n \
      Name-Email: $GPG_EMAIL_ADDRESS\n \
      Expire-Date: 0\n \
      Passphrase: $GPG_PASSPHRASE\n \
      %commit\n \
    %echo done" > /tmp/gen-key-script \

USER $WWW_USER
RUN gpg --homedir $PATH_TO_MISP/.gnupg --batch --gen-key /tmp/gen-key-script

## Export the public key to the webroot
RUN sh -c "gpg --homedir $PATH_TO_MISP/.gnupg --export --armor $GPG_EMAIL_ADDRESS" | tee $PATH_TO_MISP/app/webroot/gpg.asc
USER root
RUN rm -f /tmp/gen-key-script

# Background workers
RUN chmod +x $PATH_TO_MISP/app/Console/worker/start.sh
RUN echo '#!/bin/sh -e' | tee -a /etc/rc.local
RUN chmod u+x /etc/rc.local

# Have supervisor so we can start everything properly
# Redis Setup for Supervisord
RUN sed -i 's/^\(daemonize\s*\)yes\s*$/\1no/g' /etc/redis/redis.conf

RUN apt install supervisor -y
RUN echo '[supervisord]' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'nodaemon = true' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '' >> /etc/supervisor/conf.d/supervisord.conf
# RUN echo '[program:postfix]' >> /etc/supervisor/conf.d/supervisord.conf
# RUN echo 'process_name = master' >> /etc/supervisor/conf.d/supervisord.conf
# RUN echo 'directory = /etc/postfix' >> /etc/supervisor/conf.d/supervisord.conf
# RUN echo 'command = /usr/sbin/postfix -c /etc/postfix start' >> /etc/supervisor/conf.d/supervisord.conf
# RUN echo 'startsecs = 0' >> /etc/supervisor/conf.d/supervisord.conf
# RUN echo 'autorestart = false' >> /etc/supervisor/conf.d/supervisord.conf
# RUN echo '' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '[program:mysqld_safe]' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'command=mysqld_safe' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '[program:redis-server]' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'command=redis-server /etc/redis/redis.conf' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '[program:apache2]' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'command=/bin/bash -c "source /etc/apache2/envvars && exec /usr/sbin/apache2 -D FOREGROUND"' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '[program:resque]' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'command=/bin/bash $PATH_TO_MISP/app/Console/worker/start.sh' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'user = www-data' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'startsecs = 0' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'autorestart = false' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo '[program:misp-modules]' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'command=/bin/bash -c "misp-modules -s -l 127.0.0.1"' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'user = www-data' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'startsecs = 0' >> /etc/supervisor/conf.d/supervisord.conf
RUN echo 'autorestart = false' >> /etc/supervisor/conf.d/supervisord.conf

# Start the workers
### REMOVED SINCE WE USER SUPERVISORD
