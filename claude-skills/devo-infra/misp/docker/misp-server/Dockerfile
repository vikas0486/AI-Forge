RUN echo "PATH_TO_MISP=\"$PATH_TO_MISP\"" > /root/misp.config
RUN echo "GPG_EMAIL_ADDRESS=\"$GPG_EMAIL_ADDRESS\"" >> /root/misp.config
RUN echo "GPG_PASSPHRASE=\"$GPG_PASSPHRASE\"" >> /root/misp.config
RUN echo "FLAVOUR=\"$FLAVOUR\"" >> /root/misp.config
RUN echo "MISP_BASEURL=\"$MISP_BASEURL\"" >> /root/misp.config

RUN cat /root/misp.config

ADD scripts/startup.sh /startup.sh
RUN chmod 755 /startup.sh

COPY scripts/first_start /

VOLUME $PATH_TO_MISP
EXPOSE 443
ENTRYPOINT ["/startup.sh"]
CMD ["/usr/bin/supervisord","-c","/etc/supervisor/conf.d/supervisord.conf"]

