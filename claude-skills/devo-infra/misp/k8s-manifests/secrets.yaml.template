---
# MySQL Secret
apiVersion: v1
kind: Secret
metadata:
  name: misp-mysql-secret
  namespace: misp-prod
type: Opaque
stringData:
  root-password: "REPLACE_WITH_STRONG_PASSWORD"
  misp-db-password: "REPLACE_WITH_STRONG_PASSWORD"

---
# MISP Admin Secret
apiVersion: v1
kind: Secret
metadata:
  name: misp-admin-secret
  namespace: misp-prod
type: Opaque
stringData:
  admin-email: "misp-admin@devo.com"
  admin-password: "REPLACE_WITH_STRONG_PASSWORD"
  api-key: "REPLACE_AFTER_FIRST_LOGIN"

---
# Devo API Secret (for lookup upload)
apiVersion: v1
kind: Secret
metadata:
  name: devo-api-secret
  namespace: misp-prod
type: Opaque
stringData:
  api-key: "REPLACE_WITH_DEVO_API_KEY"
  api-secret: "REPLACE_WITH_DEVO_API_SECRET"
  api-url: "https://apiv2-us.devo.com"

---
# TLS Certificate Secret (optional - can use cert-manager instead)
apiVersion: v1
kind: Secret
metadata:
  name: misp-tls-secret
  namespace: misp-prod
type: kubernetes.io/tls
data:
  tls.crt: LS0tLS1CRUdJTi...  # Base64 encoded certificate
  tls.key: LS0tLS1CRUdJTi...  # Base64 encoded private key

---
# Instructions for creating secrets:
#
# 1. Copy this file: cp secrets.yaml.template secrets.yaml
# 2. Generate strong passwords:
#    openssl rand -base64 32
# 3. Replace all REPLACE_WITH_* placeholders
# 4. Apply secrets: kubectl apply -f secrets.yaml
# 5. Delete the file: rm secrets.yaml (never commit!)
# 6. Or use kubectl create secret directly:
#
#    kubectl create secret generic misp-mysql-secret \
#      --from-literal=root-password='STRONG_PASSWORD' \
#      --from-literal=misp-db-password='STRONG_PASSWORD' \
#      -n misp-prod
#
#    kubectl create secret generic misp-admin-secret \
#      --from-literal=admin-email='misp-admin@devo.com' \
#      --from-literal=admin-password='STRONG_PASSWORD' \
#      -n misp-prod
#
#    kubectl create secret generic devo-api-secret \
#      --from-literal=api-key='YOUR_DEVO_API_KEY' \
#      --from-literal=api-secret='YOUR_DEVO_API_SECRET' \
#      --from-literal=api-url='https://apiv2-us.devo.com' \
#      -n misp-prod
